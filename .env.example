GEMINI_API_KEY=your_gemini_api_key_here

# Server Ports
DASHBOARD_PORT=8502
API_PORT=8000

# Chat Session (security-and-test-improvement)
CHAT_SESSION_TTL_SEC=1800
CHAT_SESSION_MAX_PER_IP=20
CHAT_SESSION_MAX_TOTAL=1000

# Custom Query Safety
CUSTOM_QUERY_TIMEOUT_SEC=10
# Semicolon-separated absolute paths; empty = use default (database/archive_2025.db)
ARCHIVE_DB_WHITELIST=
